# .env.example - Project Polaris 系统配置模板

# 🌟 1. 大模型配置 (LLM Settings)
OPENAI_API_KEY=your_sk_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v3.1
VISION_MODEL=qwen-vl-max

# 🌟 2. 飞书底座配置 (Feishu Bitable IDs)
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=secret_xxx
FEISHU_APP_TOKEN=bascn_xxx

# 核心表 ID
FEISHU_TABLE_ID_JOBS=tblnHFxM #岗位表
FEISHU_TABLE_ID_CONFIG=tbl2fgL #配置表
FEISHU_TABLE_ID_PROMPTS=tbl2jP9Bq3c #提示词表
FEISHU_TABLE_ID_RESUMES=tblXbdNHn #简历表
FEISHU_TABLE_ID_PREFERENCES=tbltLDLR #偏好表

# 🌟 3. 外部调研配置
SERPER_API_KEY=your_serper_key_here